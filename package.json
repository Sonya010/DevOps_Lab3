{
  "name": "mywebapp",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "start": "node migrate.js && node app.js",
    "test": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":40}}'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Task Tracker web application",
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!migrate.js",
      "!jest.config.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ]
  }
}
